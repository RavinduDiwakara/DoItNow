<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Doitnow" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/splash_background</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_green</item>
        <item name="android:windowBackground">@color/login_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.Doitnow" parent="Base.Theme.Doitnow" />

    <style name="CircleImage" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="Theme.Doitnow.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/dialog_background</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Doitnow.Dialog</item>
        <item name="colorPrimary">@color/accent_green</item>
    </style>

    <style name="ShapeAppearance.Doitnow.Dialog" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">28dp</item>
    </style>
</resources>